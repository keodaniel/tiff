---
import Footer from '../Footer.astro';
---

<div class="slide about">
  <section id="about">
    <div class="section-inner">
      <h2 class="section-heading">Meet Coach Tiff</h2>
      <div class="about-layout">
        <div class="about-body">
          <p class="about-text">
            Coach Tiff is a USA Weightlifting Level 2 Coach and national medalist with a well-rounded athletic
            background and a reputation for precision and poise. She brings six years of experience as a competitive
            lifter and four years as a dedicated coach, helping athletes of all levels build strength, confidence,
            and consistency.
          </p>
          <p class="about-text">
            Before weightlifting, Tiff spent 15 years as a gymnast — five of those as a coach — and competed in
            CrossFit, where her passion for movement and attention to detail flourished. She discovered Olympic
            weightlifting at age 22 and was drawn to its technical demands.
          </p>
          <p class="about-text">
            Known for her steady presence, sharp eye, and signature snack stash, Coach Tiff has guided lifters to
            national-level competitions and is a trusted member of the weightlifting community. Whether you're
            learning the basics or preparing for the national stage, Coach Tiff brings knowledge, commitment, and
            a calm, focused energy to the platform.
          </p>
        </div>
        <div class="about-sidebar">
          <div class="about-photo-wrap">
            <img class="about-photo" src="/tiff_profile.png" alt="Coach Tiff" />
          </div>
          <aside class="credentials-badge">
            <h3 class="credentials-title">Background & Credentials</h3>
            <ul class="credentials-list" role="list">
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>USAW Level 2 Coach</span>
              </li>
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>United States Marine Corps Veteran</span>
              </li>
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>M.A. Psychology</span>
              </li>
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>National Medalist</span>
              </li>
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>6 Years Competitive Lifting</span>
              </li>
              <li class="credentials-item">
                <span class="credentials-icon" aria-hidden="true">◆</span>
                <span>15 Years Gymnastics Background</span>
              </li>
            </ul>
          </aside>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</div>
