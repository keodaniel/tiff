---
import ProgramCard from '../ProgramCard.astro';
import type staticPrograms from '../../data/programs.json';
import Footer from '../Footer.astro';

interface Props {
  programs: typeof staticPrograms;
}

const { programs } = Astro.props;
---

<div class="slide">
  <section id="membership" class="membership">
    <div class="section-inner">
      <h2 class="section-heading">Memberships</h2>
      <p class="section-subheading">Choose the membership that fits your goals and your life.</p>
      <div class="cards-grid">
        {programs.map((program) => (
          <ProgramCard
            id={program.id}
            tag={program.tag}
            title={program.title}
            price={program.price}
            period={program.period}
            features={program.features}
            featured={program.featured}
            badges={program.badges ?? []}
            program={program.program}
            gradient={program.gradient}
            ctaStyle={program.ctaStyle as 'primary' | 'secondary'}
            stripeUrl={program.stripeUrl}
            inquireOnly={program.inquireOnly}
          />
        ))}
      </div>
    </div>
  </section>
  <Footer />
</div>
