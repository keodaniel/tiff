---
import ShopCard from '../ShopCard.astro';
import shopItems from '../../data/shop.json';

const courses = shopItems.filter((item) => item.category === 'courses');
---

<div class="slide">
  <section id="home" class="hero">
    <div class="hero-inner">
      <div class="hero-photo-wrap">
        <img
          class="hero-photo"
          src="/tiff_profile_red.png"
          alt="Coach Tiff, head coach at Tank Performance and Weightlifting"
          width="200"
          height="200"
        />
      </div>
      <div>
        <p class="hero-eyebrow">Olympic Weightlifting + Military Strength &amp; Conditioning Coach</p>
        <h1 class="hero-name">Coach Tiff</h1>
    <p class="hero-club">Tank Performance and Weightlifting</p>
        <div class="hero-actions">
          <button class="btn btn-primary" data-go-slide="1">Promo Codes</button>
          <button class="btn btn-primary" data-go-slide="2">View Memberships</button>
<button class="btn btn-primary" data-go-slide="4">About Me</button>
        </div>
        {courses.length > 0 && (
          <div class="hero-courses">
            {courses.map((item) => (
              <ShopCard
                id={item.id}
                tag={item.tag}
                title={item.title}
                price={item.price}
                features={item.features}
                badges={item.badges ?? []}
                category={item.category}
                stripeUrl={'stripeUrl' in item ? item.stripeUrl : undefined}
                featured={true}
              />
            ))}
          </div>
        )}
      </div>
      <div class="scroll-hint" aria-hidden="true">→</div>
    </div>
  </section>
</div>
