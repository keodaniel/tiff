---
---

<div class="slide">
  <section id="home" class="hero">
    <div class="hero-inner">
      <div class="hero-photo-wrap">
        <img
          class="hero-photo"
          src="/tiff_profile.jpeg"
          alt="Coach Tiff, head coach at Blackheart Barbell"
          width="200"
          height="200"
        />
      </div>
      <div>
        <p class="hero-eyebrow">Olympic Weightlifting + Military Strength &amp; Conditioning Coach</p>
        <h1 class="hero-name">Coach Tiff</h1>
        <p class="hero-club">Blackheart Barbell</p>
        <div class="hero-actions">
          <button class="btn btn-secondary" data-go-slide="1">Promo Codes</button>
          <button class="btn btn-primary" data-go-slide="2">View Programs</button>
          <button class="btn btn-secondary" data-go-slide="3">Apply for Coaching</button>
          <button class="btn btn-secondary" data-go-slide="4">About Me</button>
        </div>
      </div>
      <div class="scroll-hint" aria-hidden="true">→</div>
    </div>
  </section>
</div>
