---
import ShopCard from '../ShopCard.astro';
import shopItems from '../../data/shop.json';

interface Props {
  eyebrow?: string;
  clubName?: string;
}

const {
  eyebrow = 'Olympic Weightlifting + Tactical Strength & Conditioning Coach',
  clubName = 'Tank Performance and Weightlifting',
} = Astro.props;

const courses = shopItems.filter((item) => item.category === 'courses');
---

<div class="slide">
  <section id="home" class="hero">
    <div class="hero-inner">
      <div class="hero-photo-wrap">
        <img
          class="hero-photo"
          src="/tiff_profile.png"
          alt="Coach Tiff, head coach at Tank Performance and Weightlifting"
          width="200"
          height="200"
        />
      </div>
      <div class="hero-content">
        <p class="hero-eyebrow">{eyebrow}</p>
        <h1 class="hero-name">{clubName}</h1>
        <p class="hero-club">Owned and Operated by Coach Tiff</p>
        <div class="hero-actions">
          <button class="btn btn-primary"   data-go-slide="1">View Memberships →</button>
          <button class="btn btn-secondary" data-go-slide="2">Promo Codes</button>
          <button class="btn btn-secondary" data-go-slide="3">About Me</button>
        </div>
        {courses.length > 0 && (
          <div class="hero-courses">
            {courses.map((item) => (
              <ShopCard
                id={item.id}
                tag={item.tag}
                title={item.title}
                price={item.price}
                features={item.features}
                badges={item.badges ?? []}
                category={item.category}
                stripeUrl={'stripeUrl' in item ? item.stripeUrl : undefined}
                featured={true}
              />
            ))}
          </div>
        )}
      </div>
      <img
        class="hero-tpc-logo"
        src="/tpc_logo_red_no_bg.png"
        alt="Tank Performance and Weightlifting"
      />
      <div class="scroll-hint" aria-hidden="true">→</div>
    </div>
  </section>
</div>
