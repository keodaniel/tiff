---
interface Feature {
  text: string;
  url?: string;
}

interface Props {
  id: string;
  tag: string;
  title: string;
  price: number;
  period: string;
  features: Feature[];
  featured?: boolean;
  badge?: string | null;
  program: string;
  ctaStyle?: 'primary' | 'secondary';
  stripeUrl?: string;
}

const { id, tag, title, price, period, features, featured = false, badge, program, stripeUrl } = Astro.props;
---

<article class={`card${featured ? ' card--featured' : ''}`} aria-label={`${title} membership`}>
  {badge && <div class="card-badge">{badge}</div>}
  <p class="card-tag">{tag}</p>
  <div class="card-header">
    <h3 class="card-title">{title}</h3>
    <div class="card-price">
      <span class="card-price-amount">${price}</span>
      <span class="card-price-period">/{period}</span>
    </div>
  </div>
  <ul class="card-features" role="list">
    {features.map((feature) => (
      <li class="card-feature-item">
        <span class="feature-check" aria-hidden="true">✓</span>
        <span>
          {feature.url
            ? <a href={feature.url} target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.85);text-decoration:underline;">{feature.text}</a>
            : feature.text}
        </span>
      </li>
    ))}
  </ul>
  <div class="card-cta-group">
    <button class="btn btn-secondary card-cta" data-go-slide="3" data-program={program}>Inquire</button>
        <a href={stripeUrl ?? `/checkout?membership=${id}`} class="btn btn-primary card-cta">Join Now</a>
  </div>
</article>
