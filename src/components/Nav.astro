---
interface NavLink {
  label: string;
  slide?: number;
  href?: string;
}

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a class="nav-logo" href="#" data-go-slide="0" aria-label="Home">
      <img class="nav-logo-img" src="/tank_perf_wl_logo.jpg" alt="Tank Performance and Weightlifting" />
    </a>
    <button
      class="nav-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <ul class="nav-menu" id="nav-menu" role="list">
      {links.map((link) => (
        <li>
          {link.href
            ? <a class="nav-link nav-link--shop" href={link.href}>{link.label}</a>
            : <button class="nav-link nav-link--btn" data-go-slide={link.slide}>{link.label}</button>
          }
        </li>
      ))}
    </ul>
  </div>
</nav>
