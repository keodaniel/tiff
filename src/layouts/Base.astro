---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'Coach Tiff | Blackheart Barbell',
  description = 'USA Weightlifting Level 2 Coach and national medalist. Olympic weightlifting, strength, and conditioning programs in-person and remote.',
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class={bodyClass || undefined}>
    <slot />
  </body>
</html>
