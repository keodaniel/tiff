sequenceDiagram
    participant U as User
    participant LP as login page
    participant API as api/admin/login
    participant Auth as lib/auth.ts
    participant MW as middleware

    U->>LP: GET /admin/login
    LP->>Auth: verifySession(cookie, SESSION_SECRET)
    alt Already authenticated
        LP-->>U: 302 to /admin
    else Not authenticated
        LP-->>U: Show password form
    end

    U->>API: POST password field
    API->>Auth: checkPassword(input, env.ADMIN_PASSWORD)
    note over Auth: Simple string equality, no hashing
    alt Wrong password
        API-->>U: 302 to /admin/login?error=1
    else Correct password
        API->>Auth: signSession(env.SESSION_SECRET)
        note over Auth: HMAC-SHA256 signed token with iat timestamp
        note over Auth: token = base64url(payload).signature
        Auth-->>API: signed token string
        API-->>U: Set-Cookie admin_session=token HttpOnly Secure 24hr
        API-->>U: 302 to /admin
    end

    note over U,MW: Every subsequent /admin/* request

    U->>MW: GET /admin/* with cookie
    MW->>Auth: verifySession(token, env.SESSION_SECRET)
    note over Auth: Split at last dot, recompute HMAC, compare
    note over Auth: Decode iat, verify iat + 86400 is after now
    alt Signature mismatch or expired
        MW-->>U: 302 to /admin/login
    else Valid session
        MW-->>U: Render admin page
    end
