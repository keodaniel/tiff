---
import Base from '../layouts/Base.astro';
---

<Base title="Cart | Coach Tiff" bodyClass="page-standalone">
  <header class="checkout-header">
    <a href="/" class="checkout-logo-link" aria-label="Home — Tank Performance and Weightlifting">
      <img src="/blackheartbarbell.png" alt="Tank Performance and Weightlifting" class="checkout-logo" />
    </a>
    <a href="/" class="cart-back-link">← Back to Home</a>
  </header>

  <main class="checkout-main">
    <div class="section-inner checkout-inner">
      <h1 class="section-heading">*UNDER CONSTRUCTION* Your Cart</h1>

      <div id="cart-empty" hidden>
        <p class="cart-empty-message">Your cart is empty.</p>
        <a href="/" class="btn btn-primary cart-browse-btn">Back to Home</a>
      </div>

      <div id="cart-has-items" hidden>
        <div class="checkout-layout">
          <div class="checkout-summary card" id="cart-items-panel" aria-label="Order summary"></div>

          <div class="checkout-form-panel">
            <form id="cart-checkout-form" novalidate>
              <div class="checkout-section">
                <h3 class="checkout-section-title">Contact Information</h3>
                <div class="form-group">
                  <label class="form-label" for="cart-name">Full Name</label>
                  <input
                    class="form-input"
                    type="text"
                    id="cart-name"
                    name="name"
                    autocomplete="name"
                    required
                    placeholder="Your full name"
                  />
                  <span class="form-error" id="cart-name-error" hidden>Please enter your name.</span>
                </div>
                <div class="form-group">
                  <label class="form-label" for="cart-email">Email Address</label>
                  <input
                    class="form-input"
                    type="email"
                    id="cart-email"
                    name="email"
                    autocomplete="email"
                    required
                    placeholder="you@example.com"
                  />
                  <span class="form-error" id="cart-email-error" hidden>Please enter a valid email address.</span>
                </div>
              </div>

              <div class="checkout-section">
                <h3 class="checkout-section-title">Payment</h3>
                <div class="mock-payment-panel" aria-label="Payment method placeholder — Stripe coming soon">
                  <div class="mock-card-placeholder">
                    <span class="mock-card-number">•••• •••• •••• ••••</span>
                    <div class="mock-card-row">
                      <div class="mock-card-field">
                        <span class="mock-card-label">Expiry</span>
                        <span class="mock-card-value">MM / YY</span>
                      </div>
                      <div class="mock-card-field">
                        <span class="mock-card-label">CVC</span>
                        <span class="mock-card-value">•••</span>
                      </div>
                    </div>
                  </div>
                  <p class="mock-payment-notice">
                    <span aria-hidden="true">🔒</span> Secure payment powered by Stripe — coming soon
                  </p>
                </div>
              </div>

              <div class="checkout-section">
                <label class="checkout-terms">
                  <input type="checkbox" id="cart-terms" required />
                  <span>I agree to the purchase terms and understand digital programs are non-refundable.</span>
                </label>
                <span class="form-error" id="cart-terms-error" hidden>You must agree to continue.</span>
              </div>

              <button type="submit" class="btn btn-primary form-submit" id="cart-submit">
                Complete Purchase
              </button>

              <a href="/" class="checkout-cancel-link">← Continue shopping</a>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</Base>

<script>
  import { getCart, removeFromCart, clearCart, getCartTotal } from '../lib/cart';

  function renderCart() {
    const cart = getCart();
    const emptyEl = document.getElementById('cart-empty')!;
    const itemsEl = document.getElementById('cart-has-items')!;
    const itemsPanel = document.getElementById('cart-items-panel')!;
    const submitBtn = document.getElementById('cart-submit') as HTMLButtonElement;

    if (cart.length === 0) {
      emptyEl.hidden = false;
      itemsEl.hidden = true;
      return;
    }

    emptyEl.hidden = true;
    itemsEl.hidden = false;

    const total = getCartTotal();

    itemsPanel.innerHTML = `
      <h2 class="checkout-section-title cart-summary-heading">Order Summary</h2>
      <ul class="cart-item-list" role="list">
        ${cart.map((item) => {
          const qty = item.quantity ?? 1;
          const unitPrice = (item.priceCents / 100).toFixed(0);
          const lineTotal = (item.priceCents * qty / 100).toFixed(0);
          const priceDisplay = qty > 1 ? `$${unitPrice} × ${qty}` : `$${lineTotal}`;
          const typeDisplay = item.type === 'merch'
            ? (qty > 1 ? `Qty: ${qty}` : 'Merch')
            : 'One-time purchase · Digital';
          return `
          <li class="cart-item">
            <div class="cart-item-info">
              <span class="cart-item-title">${item.title}</span>
              <span class="cart-item-type">${typeDisplay}</span>
            </div>
            <div class="cart-item-right">
              <span class="cart-item-price">${priceDisplay}</span>
              <button class="cart-remove-btn" data-remove-id="${item.id}" aria-label="Remove ${item.title}">✕</button>
            </div>
          </li>`;
        }).join('')}
      </ul>
      <div class="cart-total">
        <span class="cart-total-label">Total</span>
        <span class="cart-total-amount">$${(total / 100).toFixed(0)}</span>
      </div>
    `;

    submitBtn.textContent = `Complete Purchase — $${(total / 100).toFixed(0)}`;

    itemsPanel.querySelectorAll<HTMLButtonElement>('.cart-remove-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.removeId;
        if (id) { removeFromCart(id); renderCart(); }
      });
    });
  }

  renderCart();

  const form = document.getElementById('cart-checkout-form')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const nameInput = document.getElementById('cart-name') as HTMLInputElement;
    const emailInput = document.getElementById('cart-email') as HTMLInputElement;
    const termsInput = document.getElementById('cart-terms') as HTMLInputElement;

    let valid = true;

    (document.getElementById('cart-name-error') as HTMLElement).hidden = true;
    (document.getElementById('cart-email-error') as HTMLElement).hidden = true;
    (document.getElementById('cart-terms-error') as HTMLElement).hidden = true;
    nameInput.classList.remove('is-invalid');
    emailInput.classList.remove('is-invalid');

    if (!nameInput.value.trim()) {
      (document.getElementById('cart-name-error') as HTMLElement).hidden = false;
      nameInput.classList.add('is-invalid');
      valid = false;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())) {
      (document.getElementById('cart-email-error') as HTMLElement).hidden = false;
      emailInput.classList.add('is-invalid');
      valid = false;
    }

    if (!termsInput.checked) {
      (document.getElementById('cart-terms-error') as HTMLElement).hidden = false;
      valid = false;
    }

    if (!valid) return;

    const cart = getCart();
    const total = getCartTotal();

    const session = {
      id: 'mock_' + Math.random().toString(36).slice(2, 10),
      items: cart.map((i) => i.title),
      totalCents: total,
      customerName: nameInput.value.trim(),
      customerEmail: emailInput.value.trim(),
      status: 'paid',
      createdAt: new Date().toISOString(),
    };

    clearCart();
    window.location.href = '/cart/success?session=' + encodeURIComponent(btoa(JSON.stringify(session)));
  });
</script>
