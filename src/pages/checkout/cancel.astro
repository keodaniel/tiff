---
import Base from '../../layouts/Base.astro';
---

<Base title="Checkout Cancelled | Coach Tiff" bodyClass="page-standalone">
  <header class="checkout-header">
    <a href="/" class="checkout-logo-link" aria-label="Home — Blackheart Barbell">
      <img src="/blackheartbarbell.png" alt="Blackheart Barbell" class="checkout-logo" />
    </a>
  </header>

  <main class="checkout-main">
    <div class="section-inner checkout-confirmation">
      <div class="confirmation-icon confirmation-icon--cancel" aria-hidden="true">✕</div>
      <h1 class="confirmation-heading">Checkout Cancelled</h1>
      <p class="confirmation-message">
        Your membership was not processed. No charges were made.
      </p>
      <a href="/" class="btn btn-primary checkout-home-btn">View Memberships</a>
    </div>
  </main>
</Base>
