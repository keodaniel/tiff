---
import Base from '../../layouts/Base.astro';
---

<Base title="Membership Confirmed | Coach Tiff" bodyClass="page-standalone">
  <header class="checkout-header">
    <a href="/" class="checkout-logo-link" aria-label="Home — Blackheart Barbell">
      <img src="/blackheartbarbell.png" alt="Blackheart Barbell" class="checkout-logo" />
    </a>
  </header>

  <main class="checkout-main">
    <div class="section-inner checkout-confirmation">
      <div class="confirmation-icon" aria-hidden="true">✓</div>
      <h1 class="confirmation-heading">Membership Confirmed</h1>
      <div class="confirmation-details" id="confirmation-details">
        <p class="confirmation-membership" id="confirmation-membership"></p>
        <p class="confirmation-price" id="confirmation-price"></p>
      </div>
      <p class="confirmation-message">
        Coach Tiff will reach out within 1–2 business days to get you started.
      </p>
      <p class="confirmation-ref" id="confirmation-ref"></p>
      <a href="/" class="btn btn-primary checkout-home-btn">Back to Home</a>
    </div>
  </main>
</Base>

<script>
  const params = new URLSearchParams(window.location.search);
  const encoded = params.get('session');

  if (encoded) {
    try {
      const session = JSON.parse(atob(decodeURIComponent(encoded)));
      const membershipEl = document.getElementById('confirmation-membership');
      const priceEl = document.getElementById('confirmation-price');
      const refEl = document.getElementById('confirmation-ref');
      if (membershipEl) membershipEl.textContent = session.membershipTitle;
      if (priceEl) priceEl.textContent = '$' + (session.amountCents / 100).toFixed(0) + '/month';
      if (refEl) refEl.textContent = 'Reference: ' + session.id;
    } catch (_) {
      // silently ignore malformed session param
    }
  }
</script>
