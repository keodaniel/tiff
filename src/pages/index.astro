---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import HomeSlide from '../components/slides/HomeSlide.astro';
import PromosSlide from '../components/slides/PromosSlide.astro';
import MembershipsSlide from '../components/slides/MembershipsSlide.astro';
import AboutSlide from '../components/slides/AboutSlide.astro';
import staticPrograms from '../data/programs.json';
import staticPromos from '../data/promos.json';
import { env } from 'cloudflare:workers';

import { DEFAULT_COPY } from './api/admin/copy';

let programs = staticPrograms as typeof staticPrograms;
let promos = staticPromos as typeof staticPromos;
let homeCopy = { ...DEFAULT_COPY };
try {
  const pr = await env.SITE_DATA.get('programs:list');
  if (pr) programs = JSON.parse(pr);
} catch {}
try {
  const po = await env.SITE_DATA.get('promos:list');
  if (po) promos = JSON.parse(po);
} catch {}
try {
  const co = await env.SITE_DATA.get('copy:home');
  if (co) homeCopy = { ...DEFAULT_COPY, ...JSON.parse(co) };
} catch {}

const navLinks = [
  { label: 'Home', slide: 0 },
  { label: 'Promo Codes', slide: 1 },
  { label: 'View Memberships', slide: 2 },
  { label: 'Meet Coach Tiff', slide: 3 },
];

const slideDots = [
  { label: 'Home', index: 0 },
  { label: 'Promo Codes', index: 1 },
  { label: 'View Memberships', index: 2 },
  { label: 'Meet Coach Tiff', index: 3 },
];
---

<Base>
  <Nav links={navLinks} />

  <div class="slides-track">
    <div class="slides-inner" id="slides-inner">
      <HomeSlide eyebrow={homeCopy.eyebrow} clubName={homeCopy.clubName} />
      <PromosSlide promos={promos} />
      <MembershipsSlide programs={programs} />
      <AboutSlide />
    </div>

    <div class="slide-dots" id="slide-dots" aria-hidden="true">
      {slideDots.map((dot) => (
        <button
          class={`slide-dot${dot.index === 0 ? ' is-active' : ''}`}
          data-go-slide={dot.index}
          aria-label={dot.label}
        />
      ))}
    </div>
  </div>
</Base>

<script>
  const slidesInner = document.getElementById('slides-inner')!;
  const navToggle = document.querySelector<HTMLButtonElement>('.nav-toggle')!;
  const navMenu = document.getElementById('nav-menu')!;
  const SLIDE_COUNT = 4;
  let current = 0;

  function slideTo(index: number) {
    current = Math.max(0, Math.min(index, SLIDE_COUNT - 1));
    sessionStorage.setItem('slide', String(current));
    slidesInner.style.transform = `translateX(calc(${-current} * 100vw))`;

    document.querySelectorAll('.slide-dot').forEach((dot, i) => {
      dot.classList.toggle('is-active', i === current);
    });

    document.querySelectorAll<HTMLElement>('.nav-link[data-go-slide]').forEach((link) => {
      link.classList.toggle('is-active', parseInt(link.dataset.goSlide!, 10) === current);
    });

    navMenu.classList.remove('is-open');
    navToggle.setAttribute('aria-expanded', 'false');

    setTimeout(() => {
      const slides = slidesInner.querySelectorAll('.slide');
      const activeSlide = slides[current];
      const heading = activeSlide?.querySelector<HTMLElement>('h1, h2');
      if (heading) {
        if (!heading.hasAttribute('tabindex')) heading.setAttribute('tabindex', '-1');
        heading.focus({ preventScroll: true });
      }
    }, 420);
  }

  // Click delegation for data-go-slide
  document.addEventListener('click', (e) => {
    const el = (e.target as Element).closest<HTMLElement>('[data-go-slide]');
    if (!el) return;
    e.preventDefault();
    slideTo(parseInt(el.dataset.goSlide!, 10));
  });

  // Restore slide position on back-navigation
  const savedSlide = sessionStorage.getItem('slide');
  if (savedSlide !== null) slideTo(parseInt(savedSlide, 10));

  // Hamburger toggle
  navToggle.addEventListener('click', () => {
    const isOpen = navMenu.classList.toggle('is-open');
    navToggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Close nav on outside click
  document.addEventListener('click', (e) => {
    const siteNav = document.querySelector('.site-nav');
    if (siteNav && !siteNav.contains(e.target as Node)) {
      navMenu.classList.remove('is-open');
      navToggle.setAttribute('aria-expanded', 'false');
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') slideTo(current + 1);
    if (e.key === 'ArrowLeft') slideTo(current - 1);
  });

  // Touch/swipe
  let touchStartX = 0;
  let touchStartY = 0;
  document.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchend', (e) => {
    const dx = touchStartX - e.changedTouches[0].clientX;
    const dy = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
      slideTo(dx > 0 ? current + 1 : current - 1);
    }
  }, { passive: true });

</script>
