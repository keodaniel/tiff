---
import '../styles/style-comparison.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Style Comparison — Tank Performance & Weightlifting</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="style-comparison-page">
    <header class="style-top-bar">
      <div class="style-top-bar-inner">
        <div class="style-top-title">Tank Comparison</div>

        <nav class="style-jump-links" aria-label="Jump to comparison section">
          <a href="#nav">Nav</a>
          <a href="#hero">Hero</a>
          <a href="#heading">Heading</a>
          <a href="#card">Program Card</a>
          <a href="#workout">Workout Card</a>
          <a href="#form">Form/Input</a>
        </nav>
      </div>
    </header>

    <section class="style-page-intro">
      <div class="comparison-notice">
        Internal design comparison prototypes for Tank Performance &amp; Weightlifting branding exploration.
      </div>

      <h1>Focused Font + Color Comparison</h1>

      <p>
        Compare the same site portions across four practical variants without switching pages:
        Current, Hybrid Tactical, Hybrid Tactical with only Tank red swapped in, and the redesigned Tank Hybrid.
      </p>
    </section>

    <main class="comparison-layout">

      <!-- NAV -->
      <section id="nav" class="comparison-row">
        <div class="comparison-row-label">01 — Navigation</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header">
              <div class="style-name">Current</div>
              <div class="style-stack">Outfit · Plus Jakarta Sans · Yellow</div>
            </div>
            <div class="style-panel-body">
              <nav class="nav-sample">
                <span class="nav-logo">TANKTIFF</span>
                <div class="nav-links">
                  <a href="#" class="nav-link">Home</a>
                  <a href="#" class="nav-link">Programs</a>
                  <a href="#" class="nav-link">Shop</a>
                  <a href="#" class="nav-link nav-cart">Cart</a>
                </div>
              </nav>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header">
              <div class="style-name">Hybrid Tactical</div>
              <div class="style-stack">Bebas Neue · Plus Jakarta Sans · Yellow</div>
            </div>
            <div class="style-panel-body">
              <nav class="nav-sample">
                <span class="nav-logo">TANKTIFF</span>
                <div class="nav-links">
                  <a href="#" class="nav-link">Home</a>
                  <a href="#" class="nav-link">Programs</a>
                  <a href="#" class="nav-link">Shop</a>
                  <a href="#" class="nav-link nav-cart">Cart</a>
                </div>
              </nav>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header">
              <div class="style-name">Hybrid Red Swap</div>
              <div class="style-stack">Same as Hybrid · Yellow → Tank Red only</div>
            </div>
            <div class="style-panel-body">
              <nav class="nav-sample">
                <span class="nav-logo">TANKTIFF</span>
                <div class="nav-links">
                  <a href="#" class="nav-link">Home</a>
                  <a href="#" class="nav-link">Programs</a>
                  <a href="#" class="nav-link">Shop</a>
                  <a href="#" class="nav-link nav-cart">Cart</a>
                </div>
              </nav>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header">
              <div class="style-name">Tank Hybrid ★</div>
              <div class="style-stack">Bebas Neue · Plus Jakarta Sans · Tank UI</div>
            </div>
            <div class="style-panel-body">
              <nav class="nav-sample">
                <span class="nav-logo">TANKTIFF</span>
                <div class="nav-links">
                  <a href="#" class="nav-link">Home</a>
                  <a href="#" class="nav-link">Programs</a>
                  <a href="#" class="nav-link">Shop</a>
                  <a href="#" class="nav-link nav-cart">Cart</a>
                </div>
              </nav>
            </div>
          </article>

        </div>
      </section>

      <!-- HERO -->
      <section id="hero" class="comparison-row">
        <div class="comparison-row-label">02 — Hero Block</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header">
              <div class="style-name">Current</div>
              <div class="style-stack">Softer modern coaching brand</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header">
              <div class="style-name">Hybrid Tactical</div>
              <div class="style-stack">Tactical type, original yellow accent</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header">
              <div class="style-name">Hybrid Red Swap</div>
              <div class="style-stack">Same layout, Tank red accent only</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header">
              <div class="style-name">Tank Hybrid ★</div>
              <div class="style-stack">Tactical type plus Tank palette</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>

        </div>
      </section>

      <!-- HEADING -->
      <section id="heading" class="comparison-row">
        <div class="comparison-row-label">03 — Section Heading</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header"><div class="style-name">Current</div><div class="style-stack">Outfit heading</div></div>
            <div class="style-panel-body">
              <h2 class="section-heading">Programs Built for Stronger Athletes</h2>
              <p class="section-subheading">Structured training blocks designed for Olympic lifters, CrossFit athletes, and tactical professionals.</p>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header"><div class="style-name">Hybrid Tactical</div><div class="style-stack">Bebas heading, yellow accent</div></div>
            <div class="style-panel-body">
              <h2 class="section-heading">Programs Built for Stronger Athletes</h2>
              <p class="section-subheading">Structured training blocks designed for Olympic lifters, CrossFit athletes, and tactical professionals.</p>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header"><div class="style-name">Hybrid Red Swap</div><div class="style-stack">Bebas heading, red accent only</div></div>
            <div class="style-panel-body">
              <h2 class="section-heading">Programs Built for Stronger Athletes</h2>
              <p class="section-subheading">Structured training blocks designed for Olympic lifters, CrossFit athletes, and tactical professionals.</p>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header"><div class="style-name">Tank Hybrid ★</div><div class="style-stack">Bebas heading, Tank UI</div></div>
            <div class="style-panel-body">
              <h2 class="section-heading">Programs Built for Stronger Athletes</h2>
              <p class="section-subheading">Structured training blocks designed for Olympic lifters, CrossFit athletes, and tactical professionals.</p>
            </div>
          </article>

        </div>
      </section>

      <!-- CARD -->
      <section id="card" class="comparison-row">
        <div class="comparison-row-label">04 — Program Card</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header"><div class="style-name">Current</div><div class="style-stack">Existing softer card styling</div></div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header"><div class="style-name">Hybrid Tactical</div><div class="style-stack">Same card, tactical heading</div></div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header"><div class="style-name">Hybrid Red Swap</div><div class="style-stack">Same card/background, red accent only</div></div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header"><div class="style-name">Tank Hybrid ★</div><div class="style-stack">Production Tank card treatment</div></div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>

        </div>
      </section>

      <!-- WORKOUT -->
      <section id="workout" class="comparison-row">
        <div class="comparison-row-label">05 — Workout / Tactical Data Card</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header"><div class="style-name">Current</div><div class="style-stack">Baseline typography</div></div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header"><div class="style-name">Hybrid Tactical</div><div class="style-stack">DM Mono data, yellow accent</div></div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header"><div class="style-name">Hybrid Red Swap</div><div class="style-stack">Same workout card, red accent only</div></div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header"><div class="style-name">Tank Hybrid ★</div><div class="style-stack">Tank surface + red data states</div></div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>

        </div>
      </section>

      <!-- FORM -->
      <section id="form" class="comparison-row">
        <div class="comparison-row-label">06 — Form / Input Treatment</div>
        <div class="comparison-columns">

          <article class="style-panel current-style">
            <div class="style-panel-header"><div class="style-name">Current</div><div class="style-stack">Current input feel</div></div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="current-name">Athlete Name</label>
                <input id="current-name" class="form-input" placeholder="Enter name" />
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-yellow">
            <div class="style-panel-header"><div class="style-name">Hybrid Tactical</div><div class="style-stack">Same input, yellow focus</div></div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="hybrid-name">Athlete Name</label>
                <input id="hybrid-name" class="form-input" placeholder="Enter name" />
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>

          <article class="style-panel hybrid-red-swap">
            <div class="style-panel-header"><div class="style-name">Hybrid Red Swap</div><div class="style-stack">Same input, red focus only</div></div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="red-name">Athlete Name</label>
                <input id="red-name" class="form-input" placeholder="Enter name" />
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>

          <article class="style-panel tank-hybrid">
            <div class="style-panel-header"><div class="style-name">Tank Hybrid ★</div><div class="style-stack">Tank input/surface treatment</div></div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="tank-name">Athlete Name</label>
                <input id="tank-name" class="form-input" placeholder="Enter name" />
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>

        </div>
      </section>

    </main>
  </body>
</html>
