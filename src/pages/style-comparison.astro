---
import '../styles/style-comparison.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Style Comparison — Tank Performance & Weightlifting</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="style-comparison-page">
    <header class="style-top-bar">
      <div class="style-top-bar-inner">
        <div class="style-top-title">TankTiff Website Style Matrix</div>

        <nav class="style-jump-links" aria-label="Jump to comparison section">
          <a href="#nav">Nav</a>
          <a href="#hero">Hero</a>
          <a href="#card">Program Card</a>
          <a href="#workout">Workout</a>
          <a href="#form">Form/Input</a>
          <a href="#promo">Promo</a>
          <a href="#about">About</a>
        </nav>
      </div>
    </header>

    <section class="style-page-intro">
      <div class="comparison-notice">
        Font Toggle: Outfit ↔ Bebas Neue • DM Mono Everywhere
      </div>

      <h1>Red Brand Comparison</h1>

      <p>
        Compare the same components across two typography choices.
        All variants use DM Mono for metadata, labels, badges, and tactical data.
        "Current Site" panels show the live implementation.
      </p>
    </section>

    <main class="comparison-layout">

      <!-- NAV -->
      <section id="nav" class="comparison-row">
        <div class="comparison-row-label">00 — Navigation</div>

        <div class="comparison-columns">
          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Mobile — Collapsed + Expanded</div>
              <div class="style-stack">Current Implementation</div>
            </div>
            <div class="style-panel-body" style="padding:0; overflow:hidden;">
              <div class="demo-nav-bar">
                <img class="demo-nav-logo-img" src="/tpc_logo_red_no_bg.png" alt="Tank Performance and Weightlifting logo" />
                <div class="demo-nav-hamburger">
                  <div class="demo-nav-bar-line"></div>
                  <div class="demo-nav-bar-line"></div>
                  <div class="demo-nav-bar-line"></div>
                </div>
              </div>
              <div class="demo-nav-dropdown">
                <div class="demo-nav-item">Home</div>
                <div class="demo-nav-item">Promo Codes</div>
                <div class="demo-nav-item">Memberships</div>
                <div class="demo-nav-item">About Coach Tiff</div>
                <div class="demo-nav-item demo-nav-item--shop">Shop ↗</div>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Desktop — Inline Links</div>
              <div class="style-stack">Current Implementation</div>
            </div>
            <div class="style-panel-body" style="padding:0; overflow:hidden;">
              <div class="demo-desktop-nav">
                <img class="demo-nav-logo-img" src="/tpc_logo_red_no_bg.png" alt="Tank Performance and Weightlifting logo" />
                <div class="demo-desktop-links">
                  <div class="demo-desktop-link">Home</div>
                  <div class="demo-desktop-link">Promos</div>
                  <div class="demo-desktop-link">Memberships</div>
                  <div class="demo-desktop-link">About</div>
                  <div class="demo-desktop-link demo-desktop-link--shop">Shop ↗</div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- HERO -->
      <section id="hero" class="comparison-row">
        <div class="comparison-row-label">01 — Hero Block</div>

        <div class="comparison-columns comparison-columns--3">
          <article class="style-panel current-theme">
            <div class="style-panel-header">
              <div class="style-name">Current Site</div>
              <div class="style-stack">Outfit + Plus Jakarta Sans · Live</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-hero-wrap">
                <div class="demo-hero-photo-ring">
                  <img class="demo-hero-photo" src="/tiff_profile.png" alt="Coach Tiff" />
                </div>
                <p class="demo-hero-eyebrow">Olympic Weightlifting + Military Strength Coach</p>
                <h2 class="demo-hero-name">Coach Tiff</h2>
                <p class="demo-hero-club">Tank Performance and Weightlifting</p>
                <div class="demo-hero-btns">
                  <button class="demo-btn-full">Promo Codes</button>
                  <button class="demo-btn-full">View Memberships</button>
                  <button class="demo-btn-full">About Me</button>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="hero-eyebrow"><div class="hero-eyebrow-dot"></div><span>Olympic Weightlifting Coaching</span></div>
              <h2 class="hero-heading">Tank Performance<br />&amp; Weightlifting</h2>
              <p class="hero-sub">Olympic weightlifting coaching, strength programs, and tactical-style training tools.</p>
              <div class="hero-buttons">
                <a href="#" class="btn-primary">Apply for Coaching →</a>
                <a href="#" class="btn-secondary">Browse Programs</a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- PROGRAM CARD -->
      <section id="card" class="comparison-row">
        <div class="comparison-row-label">02 — Program Card</div>

        <div class="comparison-columns comparison-columns--3">
          <article class="style-panel current-theme">
            <div class="style-panel-header">
              <div class="style-name">Current Site — ShopCard</div>
              <div class="style-stack">Outfit + Plus Jakarta Sans · Live</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-shop-card">
                <div class="demo-card-banner">
                  <p class="demo-card-tag">Course</p>
                  <h3 class="demo-shop-title">Foundational Strength 1</h3>
                </div>
                <div class="demo-card-body">
                  <div class="demo-card-price">
                    <span class="demo-card-price-amount">$49</span>
                    <span class="demo-card-price-period">one time</span>
                  </div>
                  <ul class="demo-features" role="list">
                    <li class="demo-feature-item"><span class="demo-feature-check" aria-hidden="true">✓</span><span>6-week Olympic lifting and strength cycle</span></li>
                    <li class="demo-feature-item"><span class="demo-feature-check" aria-hidden="true">✓</span><span>3 training days per week</span></li>
                    <li class="demo-feature-item"><span class="demo-feature-check" aria-hidden="true">✓</span><span>Beginner-friendly programming</span></li>
                  </ul>
                  <a href="#" class="btn-primary">Sign Up Now</a>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="program-card">
                <div class="card-category">Strength Program</div>
                <h3 class="card-title">Foundational Strength 1</h3>
                <p class="card-desc">6-week Olympic lifting and strength cycle</p>
                <div class="card-badges">
                  <span class="badge">6 Weeks</span>
                  <span class="badge">3 Days / Week</span>
                  <span class="badge">Beginner Friendly</span>
                </div>
                <div class="card-footer">
                  <span class="card-price">$49</span>
                  <button class="card-cta">Get Program</button>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- WORKOUT -->
      <section id="workout" class="comparison-row">
        <div class="comparison-row-label">03 — Workout / Tactical Data Card</div>

        <div class="comparison-columns">
          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="workout-card">
                <div class="workout-header">
                  <span class="workout-week-label">Week 1 / Day 1</span>
                  <span class="workout-status">In Progress</span>
                </div>
                <div class="workout-exercises">
                  <div class="exercise-row"><span class="exercise-name">Front Squat</span><span class="exercise-params">3 × 10</span><span class="exercise-pct">@ 65%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Snatch High Pull + Snatch Above Knee</span><span class="exercise-params">4 × 2+1</span><span class="exercise-pct">@ 70%</span></div>
                  <div class="exercise-row"><span class="exercise-name">Jerk with Pause in Split</span><span class="exercise-params">4 × 3</span><span class="exercise-pct">@ 75%</span></div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- FORM -->
      <section id="form" class="comparison-row">
        <div class="comparison-row-label">04 — Form / Input Treatment</div>

        <div class="comparison-columns">
          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="red-outfit-name">Athlete Name</label>
                <input id="red-outfit-name" class="form-input" placeholder="Enter name" />
                <label class="form-label" for="red-outfit-goal">Training Goal</label>
                <textarea id="red-outfit-goal" class="form-input form-textarea" placeholder="Build strength, improve lifts, prepare for competition..."></textarea>
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="mini-form">
                <label class="form-label" for="red-bebas-name">Athlete Name</label>
                <input id="red-bebas-name" class="form-input" placeholder="Enter name" />
                <label class="form-label" for="red-bebas-goal">Training Goal</label>
                <textarea id="red-bebas-goal" class="form-input form-textarea" placeholder="Build strength, improve lifts, prepare for competition..."></textarea>
                <a href="#" class="btn-primary">Submit</a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- PROMO CARD -->
      <section id="promo" class="comparison-row">
        <div class="comparison-row-label">05 — Promo Card</div>

        <div class="comparison-columns">
          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-promo-card">
                <span class="demo-promo-brand">Barbell Apparel</span>
                <p class="demo-promo-label">Performance athletic wear engineered for Olympic weightlifting. Use code for 15% off your entire order.</p>
                <div class="demo-promo-code-row">
                  <span class="demo-promo-code">COACHTIFF15</span>
                  <button class="demo-promo-copy-btn">Copy</button>
                </div>
                <a href="#" class="demo-promo-shop-link">Shop Now ↗</a>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-promo-card">
                <span class="demo-promo-brand">Barbell Apparel</span>
                <p class="demo-promo-label">Performance athletic wear engineered for Olympic weightlifting. Use code for 15% off your entire order.</p>
                <div class="demo-promo-code-row">
                  <span class="demo-promo-code">COACHTIFF15</span>
                  <button class="demo-promo-copy-btn">Copy</button>
                </div>
                <a href="#" class="demo-promo-shop-link">Shop Now ↗</a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- ABOUT + CREDENTIALS -->
      <section id="about" class="comparison-row">
        <div class="comparison-row-label">06 — About + Credentials</div>

        <div class="comparison-columns">
          <article class="style-panel red-theme outfit-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Outfit</div>
              <div class="style-stack">Outfit + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-about-layout">
                <div>
                  <h2 class="demo-section-heading">Meet Coach Tiff</h2>
                  <p class="demo-about-text">Coach Tiff is a USA Weightlifting Level 2 Coach and national medalist with six years of competitive lifting and four years as a dedicated coach, helping athletes at all levels build strength, confidence, and consistency.</p>
                </div>
                <aside class="demo-credentials-badge">
                  <h3 class="demo-credentials-title">Credentials</h3>
                  <ul class="demo-credentials-list" role="list">
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>USAW Level 2 Coach</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>National Medalist</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>6 Years Competitive Lifting</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>15 Years Gymnastics Background</span></li>
                  </ul>
                </aside>
              </div>
            </div>
          </article>

          <article class="style-panel red-theme bebas-theme">
            <div class="style-panel-header">
              <div class="style-name">Red Tactical / Bebas</div>
              <div class="style-stack">Bebas Neue + DM Mono</div>
            </div>
            <div class="style-panel-body">
              <div class="demo-about-layout">
                <div>
                  <h2 class="demo-section-heading">Meet Coach Tiff</h2>
                  <p class="demo-about-text">Coach Tiff is a USA Weightlifting Level 2 Coach and national medalist with six years of competitive lifting and four years as a dedicated coach, helping athletes at all levels build strength, confidence, and consistency.</p>
                </div>
                <aside class="demo-credentials-badge">
                  <h3 class="demo-credentials-title">Credentials</h3>
                  <ul class="demo-credentials-list" role="list">
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>USAW Level 2 Coach</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>National Medalist</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>6 Years Competitive Lifting</span></li>
                    <li class="demo-credentials-item"><span class="demo-credentials-icon" aria-hidden="true">◆</span><span>15 Years Gymnastics Background</span></li>
                  </ul>
                </aside>
              </div>
            </div>
          </article>
        </div>
      </section>

    </main>
  </body>
</html>
