---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import diag1 from '../../../docs/01-system-overview.mmd?raw';
import diag2 from '../../../docs/02-request-flow.mmd?raw';
import diag3 from '../../../docs/03-data-model.mmd?raw';
import diag4 from '../../../docs/04-auth-flow.mmd?raw';
import diag5 from '../../../docs/05-component-tree.mmd?raw';
import diag6 from '../../../docs/06-build-pipeline.mmd?raw';

const diagrams = [
  {
    number: 1,
    title: 'System Overview',
    desc: "Bird's-eye view — GitHub to browser via Cloudflare Pages CI, the SSR Worker, and KV.",
    src: diag1,
    file: 'src/docs/01-system-overview.mmd',
  },
  {
    number: 2,
    title: 'Request Flow',
    desc: 'How a single HTTP request travels: CF Pages → Astro Worker → Middleware → Route Handler → KV → HTML.',
    src: diag2,
    file: 'src/docs/02-request-flow.mmd',
  },
  {
    number: 3,
    title: 'Data Model',
    desc: 'Everything stored in Cloudflare KV (SITE_DATA) — all keys, their JSON shapes, and relationships.',
    src: diag3,
    file: 'src/docs/03-data-model.mmd',
  },
  {
    number: 4,
    title: 'Auth Flow',
    desc: 'Full admin login cycle — password POST, HMAC-SHA256 session signing, cookie, and middleware verification.',
    src: diag4,
    file: 'src/docs/04-auth-flow.mmd',
  },
  {
    number: 5,
    title: 'Component Tree',
    desc: 'Every Astro page and component, showing how layouts wrap pages and slide components nest together.',
    src: diag5,
    file: 'src/docs/05-component-tree.mmd',
  },
  {
    number: 6,
    title: 'Build Pipeline',
    desc: 'What npm run build does — astro build output, the three fix-wrangler.mjs jobs, and CF Pages deployment.',
    src: diag6,
    file: 'src/docs/06-build-pipeline.mmd',
  },
];
---

<AdminLayout title="Architecture" wide>
  <h1 class="admin-page-title">Architecture</h1>
  <p class="dev-intro">Six Mermaid diagrams from high-level to low-level. Source files in <code>src/docs/</code> — open any <code>.mmd</code> in VS Code with the Mermaid extension for an interactive preview.</p>

  <div class="arch-tab-bar" role="tablist">
    {diagrams.map((d, i) => (
      <button
        class={`arch-tab${i === 0 ? ' is-active' : ''}`}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`panel-${i}`}
        data-idx={i}
        type="button"
      >
        <span class="arch-tab-num">{d.number}</span>
        <span class="arch-tab-label">{d.title}</span>
      </button>
    ))}
  </div>

  {diagrams.map((d, i) => (
    <div
      class={`arch-panel${i === 0 ? '' : ' is-hidden'}`}
      id={`panel-${i}`}
      role="tabpanel"
      data-panel={i}
    >
      <div class="arch-panel-meta">
        <p class="arch-section-desc">{d.desc}</p>
        <code class="arch-file">{d.file}</code>
      </div>
      <div class="mermaid-wrap">
        <pre class="mermaid">{d.src}</pre>
      </div>
      <div class="arch-panel-nav">
        {i > 0 ? (
          <button class="btn btn-secondary arch-nav-btn" data-target={i - 1} type="button">← {diagrams[i - 1].title}</button>
        ) : <span />}
        {i < diagrams.length - 1 ? (
          <button class="btn btn-secondary arch-nav-btn" data-target={i + 1} type="button">{diagrams[i + 1].title} →</button>
        ) : <span />}
      </div>
    </div>
  ))}

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLElement>('.arch-tab'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.arch-panel'));

    function show(idx: number) {
      tabs.forEach((t, i) => {
        t.classList.toggle('is-active', i === idx);
        t.setAttribute('aria-selected', String(i === idx));
      });
      panels.forEach((p, i) => p.classList.toggle('is-hidden', i !== idx));
    }

    tabs.forEach((tab, i) => tab.addEventListener('click', () => show(i)));

    document.querySelectorAll<HTMLElement>('.arch-nav-btn').forEach(btn => {
      btn.addEventListener('click', () => show(Number(btn.dataset.target)));
    });
  </script>

  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({
      startOnLoad: true,
      theme: 'dark',
      themeVariables: {
        background: '#0d0d0d',
        primaryColor: '#1a0000',
        primaryBorderColor: '#CC0000',
        primaryTextColor: '#f0f0f0',
        secondaryColor: '#1a1a1a',
        tertiaryColor: '#222222',
        lineColor: '#555555',
        textColor: '#f0f0f0',
        fontSize: '14px',
      },
    });
  </script>
</AdminLayout>
