---
import Base from '../layouts/Base.astro';
import programs from '../data/programs.json';
---

<Base title="Join a Membership | Coach Tiff" bodyClass="page-standalone">
  <header class="checkout-header">
    <a href="/" class="checkout-logo-link" aria-label="Home — Blackheart Barbell">
      <img src="/blackheartbarbell.png" alt="Blackheart Barbell" class="checkout-logo" />
    </a>
  </header>

  <main class="checkout-main">
    <div class="section-inner checkout-inner">
      <h1 class="section-heading" id="checkout-heading">Complete Your Membership</h1>
      <p class="section-subheading">Recurring monthly billing. Cancel anytime by contacting Coach Tiff.</p>

      <div class="checkout-layout">
        <aside class="checkout-summary card" aria-label="Membership summary" id="checkout-summary">
          <p class="card-tag" id="summary-tag"></p>
          <div class="card-header">
            <h2 class="card-title" id="summary-title"></h2>
            <div class="card-price">
              <span class="card-price-amount" id="summary-price"></span>
              <span class="card-price-period" id="summary-period"></span>
            </div>
          </div>
          <ul class="card-features" id="summary-features" role="list"></ul>
          <p class="checkout-billing-note">Billed monthly. Cancel anytime.</p>
        </aside>

        <div class="checkout-form-panel">
          <form id="checkout-form" novalidate>
            <div class="checkout-section">
              <h3 class="checkout-section-title">Contact Information</h3>
              <div class="form-group">
                <label class="form-label" for="checkout-name">Full Name</label>
                <input
                  class="form-input"
                  type="text"
                  id="checkout-name"
                  name="name"
                  autocomplete="name"
                  required
                  placeholder="Your full name"
                />
                <span class="form-error" id="name-error" hidden>Please enter your name.</span>
              </div>
              <div class="form-group">
                <label class="form-label" for="checkout-email">Email Address</label>
                <input
                  class="form-input"
                  type="email"
                  id="checkout-email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="you@example.com"
                />
                <span class="form-error" id="email-error" hidden>Please enter a valid email address.</span>
              </div>
            </div>

            <div class="checkout-section">
              <h3 class="checkout-section-title">Payment</h3>
            <script async
              src="https://js.stripe.com/v3/buy-button.js">
            </script>

            <stripe-buy-button
              buy-button-id="buy_btn_1TUcv1RE6BMx1xgCeeefatVq"
              publishable-key="pk_live_51OV3lRRE6BMx1xgCTYDjumnsfMJDDLH4rUr9JZX9nBRMY3FMr3wJFqW64mdNUuRtCukKxtVFtWMupebELjqhRMwa00rT6dEpTD"
            >
            </stripe-buy-button>
            </div>

            <div class="checkout-section">
              <label class="checkout-terms">
                <input type="checkbox" id="checkout-terms" required />
                <span id="terms-label">
                  I understand this is a recurring monthly charge and I can cancel anytime by
                  contacting Coach Tiff.
                </span>
              </label>
              <span class="form-error" id="terms-error" hidden>You must agree to continue.</span>
            </div>

            <button type="submit" class="btn btn-primary form-submit" id="checkout-submit">
              Complete Purchase
            </button>

            <a href="/" class="checkout-cancel-link">← Back to memberships</a>
          </form>
        </div>
      </div>
    </div>
  </main>
</Base>

<script define:vars={{ programs }}>
  const params = new URLSearchParams(window.location.search);
  const membershipId = params.get('membership');
  const membership = programs.find((p) => p.id === membershipId);

  if (!membership) {
    window.location.replace('/');
  } else {
    document.getElementById('checkout-heading').textContent = 'Complete Your Membership';
    document.getElementById('summary-tag').textContent = membership.tag;
    document.getElementById('summary-title').textContent = membership.title;
    document.getElementById('summary-price').textContent = '$' + membership.price;
    document.getElementById('summary-period').textContent = '/' + membership.period;

    const featuresList = document.getElementById('summary-features');
    membership.features.forEach((f) => {
      const li = document.createElement('li');
      li.className = 'card-feature-item';
      li.innerHTML = `<span class="feature-check" aria-hidden="true">✓</span><span>${f.text}</span>`;
      featuresList.appendChild(li);
    });

    document.getElementById('terms-label').textContent =
      `I understand this is a recurring monthly charge of $${membership.price} and I can cancel anytime by contacting Coach Tiff.`;

    document.getElementById('checkout-submit').textContent =
      `Complete Purchase — $${membership.price}/mo`;

    document.title = `Join ${membership.title} | Coach Tiff`;
  }

  const form = document.getElementById('checkout-form');

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const nameInput = document.getElementById('checkout-name');
    const emailInput = document.getElementById('checkout-email');
    const termsInput = document.getElementById('checkout-terms');

    let valid = true;

    document.getElementById('name-error').hidden = true;
    document.getElementById('email-error').hidden = true;
    document.getElementById('terms-error').hidden = true;
    nameInput.classList.remove('is-invalid');
    emailInput.classList.remove('is-invalid');

    if (!nameInput.value.trim()) {
      document.getElementById('name-error').hidden = false;
      nameInput.classList.add('is-invalid');
      valid = false;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailInput.value.trim())) {
      document.getElementById('email-error').hidden = false;
      emailInput.classList.add('is-invalid');
      valid = false;
    }

    if (!termsInput.checked) {
      document.getElementById('terms-error').hidden = false;
      valid = false;
    }

    if (!valid) return;

    const session = {
      id: 'mock_' + Math.random().toString(36).slice(2, 10),
      membershipId: membership.id,
      membershipTitle: membership.title,
      amountCents: membership.price * 100,
      customerName: nameInput.value.trim(),
      customerEmail: emailInput.value.trim(),
      status: 'paid',
      createdAt: new Date().toISOString(),
    };

    const encoded = encodeURIComponent(btoa(JSON.stringify(session)));
    window.location.href = '/checkout/success?session=' + encoded;
  });
</script>
