---
import Base from '../layouts/Base.astro';
import ShopCard from '../components/ShopCard.astro';
import shopItems from '../data/shop.json';

const courses = shopItems.filter((item) => item.category === 'courses');
const programs = shopItems.filter((item) => item.category === 'programs');
const merch = shopItems.filter((item) => item.category === 'merch');
---

<Base title="Shop Programs and Merch | Coach Tiff" bodyClass="page-standalone">
  <header class="checkout-header">
    <a href="/" class="checkout-logo-link" aria-label="Home — Blackheart Barbell">
      <img src="/blackheartbarbell.png" alt="Blackheart Barbell" class="checkout-logo" />
    </a>
    <a href="/cart" class="cart-nav-link" aria-label="View cart">
      <span class="cart-nav-icon" aria-hidden="true">🛒</span>
      <span class="cart-nav-count" id="cart-count">0</span>
    </a>
  </header>

  <main class="checkout-main">
    <div class="section-inner">
      <h1 class="section-heading">Shop</h1>
      <p class="section-subheading">Programs and merch from Blackheart Barbell.</p>

      <div class="shop-section">
        <h2 class="shop-section-title">Courses</h2>
        <p class="shop-section-desc">Remote coached courses.</p>
        <div class="cards-grid">
          {courses.map((item) => (
            <ShopCard
              id={item.id}
              tag={item.tag}
              title={item.title}
              price={item.price}
              features={item.features}
              badges={item.badges ?? []}
              category={item.category}
              stripeUrl={'stripeUrl' in item ? item.stripeUrl : undefined}
            />
          ))}
        </div>
      </div>

      <div class="shop-section">
        <h2 class="shop-section-title">Programs</h2>
        <p class="shop-section-desc">One-time purchase digital programs, delivered to your inbox.</p>
        <div class="cards-grid">
          {programs.map((item) => (
            <ShopCard
              id={item.id}
              tag={item.tag}
              title={item.title}
              price={item.price}
              features={item.features}
              badges={item.badges ?? []}
              category={item.category}
            />
          ))}
        </div>
      </div>

      <div class="shop-section">
        <h2 class="shop-section-title">Merch</h2>
        <p class="shop-section-desc">Represent Blackheart Barbell.</p>
        <div class="cards-grid">
          {merch.map((item) => (
            <ShopCard
              id={item.id}
              tag={item.tag}
              title={item.title}
              price={item.price}
              features={item.features}
              badges={item.badges ?? []}
              variants={'variants' in item ? item.variants : []}
              category={item.category}
            />
          ))}
        </div>
      </div>
    </div>
  </main>
</Base>

<script>
  import { getCartCount, addToCart, isInCart } from '../lib/cart';

  function updateCartCount() {
    const el = document.getElementById('cart-count');
    if (el) el.textContent = String(getCartCount());
  }

  updateCartCount();

  // Restore "In Cart ✓" state for non-variant items already in cart
  document.querySelectorAll<HTMLButtonElement>('.shop-add-btn:not([disabled])').forEach((btn) => {
    if (isInCart(btn.dataset.itemId!)) {
      btn.textContent = 'In Cart ✓';
      btn.setAttribute('aria-pressed', 'true');
    }
  });

  document.addEventListener('click', (e) => {
    // Size button clicks
    const sizeBtn = (e.target as Element).closest<HTMLButtonElement>('.shop-size-btn');
    if (sizeBtn) {
      const itemId = sizeBtn.dataset.itemId!;

      document.querySelectorAll<HTMLButtonElement>(`.shop-size-btn[data-item-id="${itemId}"]`).forEach((b) => {
        b.classList.remove('is-selected');
        b.setAttribute('aria-pressed', 'false');
      });
      sizeBtn.classList.add('is-selected');
      sizeBtn.setAttribute('aria-pressed', 'true');

      // Show and reset qty stepper
      const qtySelector = document.querySelector<HTMLElement>(`.shop-qty-selector[data-item-id="${itemId}"]`);
      if (qtySelector) {
        qtySelector.hidden = false;
        const stepper = qtySelector.querySelector<HTMLElement>('.shop-qty-stepper');
        if (stepper) {
          stepper.dataset.qty = '1';
          const valueEl = stepper.querySelector('.shop-qty-value');
          if (valueEl) valueEl.textContent = '1';
        }
      }

      const addBtn = document.querySelector<HTMLButtonElement>(`.shop-add-btn[data-item-id="${itemId}"]`);
      if (addBtn) {
        addBtn.removeAttribute('disabled');
        addBtn.dataset.selectedVariant = sizeBtn.dataset.size;
        addBtn.textContent = 'Add to Cart';
        addBtn.setAttribute('aria-pressed', 'false');
      }
      return;
    }

    // Quantity stepper clicks
    const qtyBtn = (e.target as Element).closest<HTMLButtonElement>('.shop-qty-btn');
    if (qtyBtn) {
      const stepper = qtyBtn.closest<HTMLElement>('.shop-qty-stepper')!;
      let qty = parseInt(stepper.dataset.qty ?? '1', 10);
      if (qtyBtn.classList.contains('shop-qty-inc')) qty = Math.min(qty + 1, 10);
      if (qtyBtn.classList.contains('shop-qty-dec')) qty = Math.max(qty - 1, 1);
      stepper.dataset.qty = String(qty);
      const valueEl = stepper.querySelector('.shop-qty-value');
      if (valueEl) valueEl.textContent = String(qty);
      return;
    }

    // Add to cart clicks
    const addBtn = (e.target as Element).closest<HTMLButtonElement>('.shop-add-btn');
    if (!addBtn || addBtn.disabled) return;

    const originalId = addBtn.dataset.itemId ?? '';
    const title = addBtn.dataset.itemTitle ?? '';
    const priceCents = parseInt(addBtn.dataset.itemPriceCents ?? '0', 10);
    const type = (addBtn.dataset.itemType ?? 'one_time') as 'one_time' | 'merch';
    const variant = addBtn.dataset.selectedVariant;
    const cartId = variant ? `${originalId}-${variant}` : originalId;

    // Read quantity from stepper if present
    let quantity = 1;
    if (variant) {
      const qtySelector = document.querySelector<HTMLElement>(`.shop-qty-selector[data-item-id="${originalId}"]`);
      quantity = parseInt(qtySelector?.querySelector<HTMLElement>('.shop-qty-stepper')?.dataset.qty ?? '1', 10);
    }

    addToCart({ id: cartId, title: variant ? `${title} (${variant})` : title, priceCents, type, quantity });

    if (variant) {
      addBtn.textContent = 'Added to Cart ✓';
      setTimeout(() => {
        document.querySelectorAll<HTMLButtonElement>(`.shop-size-btn[data-item-id="${originalId}"]`).forEach((b) => {
          b.classList.remove('is-selected');
          b.setAttribute('aria-pressed', 'false');
        });
        const qtySelector = document.querySelector<HTMLElement>(`.shop-qty-selector[data-item-id="${originalId}"]`);
        if (qtySelector) qtySelector.hidden = true;
        addBtn.disabled = true;
        addBtn.textContent = 'Select a Size';
        delete addBtn.dataset.selectedVariant;
      }, 1200);
    } else {
      addBtn.textContent = 'In Cart ✓';
      addBtn.setAttribute('aria-pressed', 'true');
    }

    updateCartCount();
  });
</script>
