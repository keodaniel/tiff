{
	"compatibility_date": "2026-04-17",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "tested-trappist",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SITE_DATA",
			"id": "393edbaaac6c4a21ab4753a90df9c3b0"
		}
	]
}